{
  "uid": "www-ws",
  "title": "What Where When — WebSockets",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "5s",
  "tags": ["ws", "socket.io", "mvp"],
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "event",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "www-prometheus" },
        "query": "label_values(ws_events_received_total, event)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": ".*" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Active WS connections",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "ws_connections{namespace=\"/game\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WS events received / sec (by event)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum by (event) (rate(ws_events_received_total{event=~\"$event\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WS events sent / sec (by event)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum by (event) (rate(ws_events_sent_total[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WS handler p95 (seconds)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, event) (rate(ws_handler_duration_seconds_bucket{event=~\"$event\"}[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WS errors / sec (expected vs unexpected)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum by (type) (rate(ws_errors_total[1m]))",
          "refId": "A"
        }
      ]
    }
  ]
}

