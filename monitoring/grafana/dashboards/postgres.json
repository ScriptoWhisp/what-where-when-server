{
  "uid": "www-postgres",
  "title": "What Where When — Postgres",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "tags": ["postgres", "db", "mvp"],
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Connections (pg_stat_activity_count)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "pg_stat_activity_count", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Transactions / sec",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit[1m])", "refId": "A" },
        { "expr": "rate(pg_stat_database_xact_rollback[1m])", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rows fetched/returned/inserted/updated/deleted",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        { "expr": "rate(pg_stat_database_tup_fetched[1m])", "refId": "A" },
        { "expr": "rate(pg_stat_database_tup_returned[1m])", "refId": "B" },
        { "expr": "rate(pg_stat_database_tup_inserted[1m])", "refId": "C" },
        { "expr": "rate(pg_stat_database_tup_updated[1m])", "refId": "D" },
        { "expr": "rate(pg_stat_database_tup_deleted[1m])", "refId": "E" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Deadlocks / sec",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(pg_stat_database_deadlocks[5m])", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Blocks read vs hit (cache efficiency)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(pg_stat_database_blks_read[1m])", "refId": "A" },
        { "expr": "rate(pg_stat_database_blks_hit[1m])", "refId": "B" }
      ]
    }
  ]
}

