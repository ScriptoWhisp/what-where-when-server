{
  "uid": "www-postgres",
  "title": "What Where When — Postgres",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "tags": ["postgres", "db", "mvp"],
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datname",
        "label": "Database (datname)",
        "type": "custom",
        "query": "www,postgres,template1",
        "current": { "text": "www", "value": "www", "selected": true },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Connections (pg_stat_database_numbackends)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "pg_stat_database_numbackends{datname=~\"$datname\"}",
          "refId": "A",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Transactions / sec",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_commit{datname=~\"$datname\"}[5m]))",
          "refId": "A",
          "legendFormat": "commit"
        },
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_rollback{datname=~\"$datname\"}[5m]))",
          "refId": "B",
          "legendFormat": "rollback"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rows fetched/returned/inserted/updated/deleted (per sec)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(pg_stat_database_tup_fetched{datname=~\"$datname\"}[5m]))",
          "refId": "A",
          "legendFormat": "fetched"
        },
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(pg_stat_database_tup_returned{datname=~\"$datname\"}[5m]))",
          "refId": "B",
          "legendFormat": "returned"
        },
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(pg_stat_database_tup_inserted{datname=~\"$datname\"}[5m]))",
          "refId": "C",
          "legendFormat": "inserted"
        },
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(pg_stat_database_tup_updated{datname=~\"$datname\"}[5m]))",
          "refId": "D",
          "legendFormat": "updated"
        },
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(pg_stat_database_tup_deleted{datname=~\"$datname\"}[5m]))",
          "refId": "E",
          "legendFormat": "deleted"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Deadlocks / sec",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(pg_stat_database_deadlocks{datname=~\"$datname\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Blocks read vs hit (cache efficiency)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(pg_stat_database_blks_read{datname=~\"$datname\"}[5m]))",
          "refId": "A",
          "legendFormat": "read"
        },
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(pg_stat_database_blks_hit{datname=~\"$datname\"}[5m]))",
          "refId": "B",
          "legendFormat": "hit"
        }
      ]
    }
  ]
}
