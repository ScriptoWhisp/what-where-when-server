{
  "uid": "www-mvp",
  "title": "What Where When — MVP",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "tags": ["mvp"],
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Targets up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(up)",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "HTTP RPS (all routes)",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(http_requests_total[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP req/min (all routes)",
      "gridPos": { "x": 6, "y": 8, "w": 9, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(increase(http_requests_total[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP avg latency (seconds)",
      "gridPos": { "x": 15, "y": 8, "w": 9, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_sum[1m])) / sum(rate(http_request_duration_seconds_count[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 latency (seconds)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx rate",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Postgres connections (app DB)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "pg_stat_database_numbackends{datname=\"www\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis commands / sec",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "sum(rate(redis_commands_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Host CPU (node_exporter)",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Node.js event loop lag (seconds)",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "www-prometheus" },
          "expr": "nodejs_eventloop_lag_seconds",
          "refId": "A"
        }
      ]
    }
  ]
}
